GITHUB_REPO=owner/repo
AWS_DEFAULT_REGION=us-east-1
DEPLOYMENT_LOG_GROUP=/aws/autoops/deployments
MCP_TRANSPORT=stdio
GITHUB_MCP_URL=http://localhost:8001/sse
CLOUDWATCH_MCP_URL=http://localhost:8002/sse
CODEREVIEW_MCP_URL=http://localhost:8003/sse
MONITORING_MCP_URL=http://localhost:8004/sse
MONITORING_METRIC_NAMESPACE=AutoOps/Services
MONITORING_SERVICE_DIMENSION=ServiceName
MONITORING_ERROR_RATE_METRIC=ErrorRate
MONITORING_LATENCY_METRIC=Latency
MONITORING_ERROR_RATE_THRESHOLD=1.0
MONITORING_LATENCY_THRESHOLD_MS=500
CHECKPOINT_DB_PATH=autoops_checkpoints.db
CODEREVIEW_A2A_URL=http://localhost:9003
A2A_BEARER_TOKEN=
# --- LLM (Groq) for supervisor routing ---
# Free API key from https://console.groq.com . Without it, the supervisor
# falls back to deterministic keyword routing.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Observability ---
# LangSmith (LangGraph tracing). Set tracing to true + provide an API key to
# send traces to the LangSmith UI.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=autoops
# Required when using a workspace-scoped service key (lsv2_sk_...): the SDK
# sends this as the x-tenant-id header. Find it via GET /workspaces. Personal
# access tokens (lsv2_pt_...) usually don't need it.
LANGSMITH_WORKSPACE_ID=
# Set to the EU endpoint if your LangSmith account is in the EU region:
# LANGCHAIN_ENDPOINT=https://eu.api.smith.langchain.com
# Logfire (structured tool/A2A spans). Provide a token to send to the Logfire
# cloud, OR set the console flag to print spans locally (no account needed).
LOGFIRE_TOKEN=
AUTOOPS_LOGFIRE_CONSOLE=false
